# x402 Facilitator environment.
#
# Fireblocks credentials live in config/facilitator.json, not here.
# See CLAUDE.md for the full config shape, or run `npm run cli -- init`.

# Server
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000
NODE_ENV=development

# Config file path (defaults to ./config/facilitator.json)
# CONFIG_PATH=./config/facilitator.json

# Payment store backend: memory | sqlite | postgres
PAYMENT_STORE=sqlite
DB_PATH=./data/facilitator.db
# POSTGRES_URL=postgres://<USER>:<PASSWORD>@localhost:5432/x402

# Management-API JWT. `npm run setup` scaffolds ./secrets/jwt-hs256.key for you;
# the server picks it up automatically. Override paths below as needed.
# X402_ADMIN_JWT_SECRET=<inline base64 or raw>   # takes precedence
# X402_ADMIN_JWT_SECRET_FILE=./secrets/jwt-hs256.key
# X402_ADMIN_JWT_JWKS_URL=https://your-idp.example.com/.well-known/jwks.json

# Mainnet vs testnet policy. Default-deny: boot refuses with mainnet
# assets configured and refuses to import new ones via the admin API.
# Set to `true` to opt into production networks.
# X402_ALLOW_MAINNET=true
